# 腾讯云SCF部署配置
# 请复制此文件为 .env 并填入你的密钥

# ========== 必填配置 ==========
# 腾讯云API密钥
# 获取方式: https://console.cloud.tencent.com/cam/ckey
TENCENT_SECRET_ID=your-secret-id-here
TENCENT_SECRET_KEY=your-secret-key-here

# ========== 可选配置 ==========
# SCF地域 (默认: ap-guangzhou)
SCF_REGION=ap-guangzhou

# SCF命名空间 (默认: default)
SCF_NAMESPACE=default

# 函数配置
SCF_RUNTIME=Nodejs18.15
SCF_TIMEOUT=10
SCF_MEMORY=128
SCF_HANDLER=index.main

# ========== 数据库配置 ==========
# 这些在SCF环境变量中配置
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=demox

# ========== JWT配置 ==========
JWT_SECRET=change-me-to-a-random-string-min-32-chars
JWT_EXPIRES_IN=30d

# ========== GitHub OAuth ==========
# GitHub OAuth App: https://github.com/settings/developers
# Client ID 为公开值，可放前端 src/configs/env.ts
# Client Secret 仅在此（SCF 环境变量），切勿提交到仓库
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

